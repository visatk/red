{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "king",
  "main": "worker/index.ts",
  "compatibility_date": "2026-06-13",
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "king-db",
      "database_id": "YOUR_D1_DATABASE_ID_HERE" // Paste ID from setup
    }
  ]
}
